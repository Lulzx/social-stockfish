# Copy to backend/.env and fill in your own values. NEVER commit the real .env.

# LLM provider — Groq (OpenAI-compatible, very fast). Get a key at https://console.groq.com
LLM_API_KEY=gsk_your_groq_api_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1

# qwen3-32b (reasoning off) for strategic candidate generation;
# llama-3.1-8b-instant for fast high-volume rollout scoring.
CANDIDATE_MODEL=qwen/qwen3-32b
CANDIDATE_REASONING=none
ROLLOUT_MODEL=llama-3.1-8b-instant
ROLLOUT_REASONING=

# Engine tuning
CANDIDATES=6
ROLLOUTS_PER_CANDIDATE=16

# Rate-limiting guardrails (stay within your provider's limits)
MAX_RPM=200
MAX_CONCURRENCY=8

# Coach voice — Supertonic TTS server (https://github.com/supertone-inc/supertonic).
# Run `supertonic serve --port 7788`. Voice "James" = built-in male voice M2.
SUPERTONIC_URL=http://127.0.0.1:7788
TTS_VOICE=M2

# Monetization. Free Game Reviews per device before the paywall; Pro unlocks
# unlimited reviews + the coach voice. Leave Stripe blank to disable billing.
FREE_REVIEWS=2
APP_URL=http://localhost:5173
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_PRICE_ID=price_...           # a recurring Price for your Pro plan
STRIPE_WEBHOOK_SECRET=whsec_...     # from `stripe listen` / dashboard webhook

# --- Alternative provider: MiniMax-M3 (OpenAI-compatible, but a reasoning model,
# --- so much slower ~60s). To use it instead, point the client at it:
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.minimax.io/v1
# CANDIDATE_MODEL=MiniMax-M3
# CANDIDATE_REASONING=low
# ROLLOUT_MODEL=MiniMax-M3
# ROLLOUT_REASONING=low
